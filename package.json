{
  "name": "dbgrid",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "npm run dev --workspace=api",
    "build": "npm run build --workspace=shared && npm run build --workspace=api && npm run build --workspace=web",
    "build:shared": "npm run build --workspace=shared",
    "test": "npm run test:unit && npm run test:api",
    "test:unit": "cd shared && npx vitest run",
    "test:api": "cd api && npx vitest run",
    "test:e2e": "playwright test",
    "db:migrate": "drizzle-kit migrate --config=api/drizzle.config.ts",
    "db:generate-migration": "drizzle-kit generate --config=api/drizzle.config.ts",
    "db:generate": "tsx ./api/scripts/db-generate.ts",
    "lint": "eslint ."
  },
  "workspaces": [
    "shared",
    "api",
    "web"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.1"
  }
}
